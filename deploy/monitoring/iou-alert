#!/bin/sh
# iou-alert "message" -- best-effort one-way alert. Never fails the caller.
# Journal + local log always; Telegram direct (api.telegram.org) if a bot token
# is installed at /etc/iou-ai/credentials/. Deliberately NOT the Cloudflare relay.
MSG="$1"
CRED=/etc/iou-ai/credentials
logger -t iou-alert -p daemon.err -- "$MSG" 2>/dev/null
echo "$(date -Is) $MSG" >> /var/log/iou-alert.log 2>/dev/null
if [ -r "$CRED/telegram-bot.token" ] && [ -r "$CRED/telegram-chat.id" ]; then
    TOK=$(cat "$CRED/telegram-bot.token"); CHAT=$(cat "$CRED/telegram-chat.id")
    curl -s -m 20 -o /dev/null -w 'telegram_http=%{http_code}\n' \
        "https://api.telegram.org/bot${TOK}/sendMessage" \
        --data-urlencode "chat_id=${CHAT}" \
        --data-urlencode "text=${MSG}" 2>/dev/null
else
    echo "telegram=not_configured"
fi
exit 0
